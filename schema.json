{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/zerber0s/windows-eid-data/main/schema.json",
  "title": "EID Quick Reference Dataset Schema",
  "type": "object",
  "required": ["dataset", "entries"],
  "properties": {
    "dataset": {
      "type": "object",
      "required": ["name", "version", "generatedAt", "license", "sources"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "generatedAt": { "type": "string", "format": "date-time" },
        "id": { "type": "string", "format": "uri" },
        "schema": { "type": "string", "format": "uri" },
        "license": {
          "type": "object",
          "required": ["name", "spdx", "notice"],
          "properties": {
            "name": { "type": "string" },
            "spdx": { "type": "string" },
            "notice": { "type": "string" }
          },
          "additionalProperties": false
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "url", "type"],
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string", "format": "uri" },
              "type": {
                "type": "string",
                "enum": ["primary", "secondary", "inspiration"]
              },
              "licenseNote": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "entry": {
      "type": "object",
      "required": [
        "id",
        "log",
        "title",
        "summary",
        "details",
        "category",
        "tags",
        "source"
      ],
      "properties": {
        "id": { "type": "integer", "minimum": 0 },
        "log": {
          "type": "string",
          "enum": ["Security", "System", "Application", "PowerShell", "Other"]
        },
        "provider": { "type": "string" },
        "channel": { "type": "string" },
        "level": {
          "type": "string",
          "enum": [
            "Information",
            "Warning",
            "Error",
            "Critical",
            "AuditSuccess",
            "AuditFailure",
            "Other"
          ]
        },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "details": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "relatedEventIds": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "mitreAttack": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["techniqueId"],
            "properties": {
              "techniqueId": { "type": "string" },
              "techniqueName": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "notesGuidance": {
          "type": "object",
          "properties": {
            "investigationPivots": {
              "type": "array",
              "items": { "type": "string" }
            },
            "commonFalsePositives": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "source": {
          "type": "object",
          "required": ["name", "url"],
          "properties": {
            "name": { "type": "string" },
            "url": { "type": "string", "format": "uri" },
            "licenseNote": { "type": "string" }
          },
          "additionalProperties": false
        },
        "lastReviewed": { "type": "string", "format": "date" }
      },
      "additionalProperties": false
    }
  }
}
